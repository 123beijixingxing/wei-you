      "name": "Auth",
      "item": [
        {
          "name": "密码登录",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile\": \"13800138000\",\n  \"password\": \"123456\",\n  \"deviceId\": \"{{deviceId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login/password"
          }
        },
        {
          "name": "短信验证码登录",
