{
  "info": {
    "name": "Weiyou Local API",
    "description": "Local API collection for the Weiyou backend. Run password login first. Login and refresh requests will write accessToken and refreshToken back into the active Postman environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "App & Auth",
      "item": [
        {
          "name": "Bootstrap",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/app/bootstrap?clientType=app&version=0.1.0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "app",
                "bootstrap"
              ],
              "query": [
                {
                  "key": "clientType",
                  "value": "app"
                },
                {
                  "key": "version",
                  "value": "0.1.0"
                }
              ]
            }
          }
        },
        {
          "name": "Password Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "  pm.environment.set('accessToken', json.data.accessToken || '');",
                  "  pm.environment.set('refreshToken', json.data.refreshToken || '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile\": \"{{mobile}}\",\n  \"password\": \"{{password}}\",\n  \"deviceId\": \"{{deviceId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login/password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login",
                "password"
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "  pm.environment.set('accessToken', json.data.accessToken || '');",
                  "  pm.environment.set('refreshToken', json.data.refreshToken || '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/token/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "token",
                "refresh"
              ]
            }
          }
        },
        {
          "name": "Device List",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/device/list",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "device",
                "list"
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"{{deviceId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            }
          }
        }
      ]
    },
